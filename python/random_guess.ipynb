   "id": "02e4b485",
   "metadata": {},
   "outputs": [],
   "source": [
    "number = random.randint(1, 10)\n",
    "while True:\n",
    "    guess = int(input(\"Guess a number (1-10): \"))\n",
    "\n",
    "    if guess == number:\n",
    "        print(\"Correct! You win!\")\n",
    "        break\n",
    "    elif guess < number:\n",
    "        print(\"Too low!\")\n",
    "    else:\n",
    "        print(\"Too high!\")"
   ]
